{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended", "helpers:pinGitHubActionDigests"],
  customManagers: [
    {
      customType: "regex",
      fileMatch: ["^versions/.*\\.json$"],
      matchStringsStrategy: "any",
      matchStrings: [
        '"version"\\s*:\\s*"v(?<currentValue>\\d+\\.\\d+\\.\\d+)"',
        '"tag"\\s*:\\s*"(?:ironclaw-)?v(?<currentValue>\\d+\\.\\d+\\.\\d+)"',
      ],
      depNameTemplate: "nearai/ironclaw",
      datasourceTemplate: "github-tags",
      extractVersionTemplate: "^(?:ironclaw-)?v?(?<version>\\d+\\.\\d+\\.\\d+)$",
      versioningTemplate: "semver-coerced",
    },
  ],
  packageRules: [
    {
      matchManagers: ["custom.regex"],
      matchDepNames: ["nearai/ironclaw"],
      groupName: "nearai/ironclaw version",
    },
  ],
}
